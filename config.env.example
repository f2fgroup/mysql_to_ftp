# MySQL to SFTP Configuration
# Copy this file to .env and customize the values

# SQL Queries Directory
SQL_DIR=sql/queries

# MySQL Output Directory (must match secure_file_priv setting)
OUTPUT_DIR=/var/lib/mysql-files

# MySQL Connection Settings
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=your_database

# SFTP Connection Settings
SFTP_HOST=sftp.example.com
SFTP_PORT=22
SFTP_USER=your_sftp_user
SFTP_PASSWORD=your_sftp_password
# Or use SSH key instead of password:
# SFTP_KEY_FILE=/path/to/your/private/key

# SFTP Remote Directory
SFTP_REMOTE_DIR=upload

# Log Configuration
# Directory where log files are stored (one timestamped file is created per run)
LOG_DIR=/tmp/mysql_to_sftp_logs
# Override LOG_FILE to use a fixed path instead of auto-generated timestamped files:
# LOG_FILE=/tmp/mysql_to_sftp.log

# Upload log file to SFTP after execution (true/false)
SFTP_UPLOAD_LOG=true
# Remote directory on the SFTP server where log files are stored
SFTP_LOG_REMOTE_DIR=upload/logs

# SQL INSERT Export
# Set to false to disable SQL export (enabled by default)
# SQL_EXPORT_ENABLED=false
# Local directory where .sql files are written (defaults to OUTPUT_DIR)
# SQL_OUTPUT_DIR=/var/lib/mysql-files
# Remote SFTP directory for .sql files (defaults to upload/sql)
SFTP_SQL_REMOTE_DIR=upload/sql

# CSV
# Column headers are always included in generated CSV files.
